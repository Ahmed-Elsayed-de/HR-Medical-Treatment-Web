          <DataField>FullCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="d">
          <DataField>d</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="sort">
          <DataField>sort</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT 
MtTickets.pharmConfirmDate,
CASE WHEN MtTickets.BillingNo IS NOT NULL 
THEN MtTickets.BillingNo WHEN MtTickets.BillingNo1 IS NOT NULL 
THEN MtTickets.BillingNo1 END AS BillingNonew, 
CASE WHEN MtTickets.Contractors IS NOT NULL 
THEN MtTickets.Contractors WHEN MtTickets.Contractors2 IS NOT NULL 
THEN MtTickets.Contractors2 END AS ContracorsAll,
HRdata.Regist_No, 
HRdata.E_Name, 
MtTickets.TreatKind, 
MtTickets.LocaldeductF AS LocaldeductF2, 
MtTickets.relatives, 
MtTickets.Localdeduct + MtTickets.Localdeduct1 + MtTickets.Localdeduct2 AS y, 
MtTickets.BillingNo, 
MtTickets.TreatType, 
MtTickets.notes, 
MtTickets.Contractors2, 
MtTickets.TarnsDate, 
MtTickets.ForeignDeduct, 
MtTickets.ForeignDeduct1, 
MtTickets.ForeignDeduct2, 
MtTickets.ForeignDeduct + MtTickets.ForeignDeduct1 + MtTickets.ForeignDeduct2 AS z, 
MtTickets.ForeignDeductF, 
MtTickets.LocaldeductF, 
MtTickets.pharmConfirm, 
HRdata.Regist_No1, 
MtTickets.BillingNo1, 
MtTickets.Id_3101, 
MtTickets.CheckS, 
MtTickets.EmpShareholdNet, 
MtTickets.PharmMemo, 
MtTickets.EmpShareholdS, 
MtTickets.LocalDeduct3, 
MtTickets.ForignDeduct, 
MtTickets.ForeignDeductS, 
MtTickets.LocaldeductS, 
DATENAME(yyyy, GETDATE()) AS CurrentYear, 
DATENAME(mm, GETDATE()) AS CurrentMonth, 
empproj.FullCode, 
CASE WHEN empproj.FullCode &lt; '10010628002' THEN 'عمومية وإدارية' ELSE 'تشغيل عام' END AS d, 
CASE WHEN empproj.FullCode &lt; '10010628002' THEN 1 ELSE 2 END AS sort
FROM         
HRdata INNER JOIN
MtTickets ON HRdata.Code = MtTickets.code LEFT OUTER JOIN
 hr.dbo.EmpProject ON HRdata.Code = EmpProject.Code LEFT OUTER JOIN
(SELECT     
 Code, 
 MAX(MonthDate) AS MaxOfMonthDate, 
 MAX(FullCode) AS FullCode
 FROM         
Attendance.dbo.Barcodeprojectcode
 WHERE     
 (MonthDate BETWEEN @DateFrom AND @DateTo)
  GROUP BY Code) AS empproj 
  ON HRdata.Code = empproj.Code
WHERE     
(MtTickets.pharmConfirm LIKE 'نعم') AND 
(MtTickets.BillingNo1 IN (@BillingNo)) AND 
(MtTickets.Contractors2 IN (@Contractors))
ORDER BY sort, MtTickets.pharmConfirmDate, MtTickets.BillingNo1</CommandText>
        <QueryParameters>
          <QueryParameter Name="@DateFrom">
            <Value>=Parameters!DateFrom.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DateTo">
            <Value>=Parameters!DateTo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@BillingNo">
            <Value>=Parameters!BillingNo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Contractors">
            <Value>=Parameters!Contractors.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="year">
      <Fields>
        <Field Name="ID">
          <DataField />
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select DATENAME(yyyy,getdate()) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="Contractors">
      <Fields>
        <Field Name="Contractors2">
          <DataField>Contractors2</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT MtTickets.Contractors2
FROM MtTickets
WHERE (MtTickets.Contractors2 Is Not Null)
and 
MtTickets.BillingNo1 in (@BillingNo)
ORDER BY MtTickets.Contractors2 asc</CommandText>
        <QueryParameters>
          <QueryParameter Name="@BillingNo">
            <Value>=Parameters!BillingNo.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="BillingNo">
      <Fields>
        <Field Name="BillingNo">
          <DataField>BillingNo</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT DISTINCT MtTickets.BillingNo
FROM MtTickets
WHERE (MtTickets.BillingNo Is Not Null)
ORDER BY MtTickets.BillingNo asc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
    <DataSet Name="CurrentMonth">
      <Fields>
        <Field Name="CurrentMonth">
          <DataField>CurrentMonth</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select 
case DATENAME(MONTH,GETDATE()) 
when 'January' then 'يناير' 
when 'February' then 'فبراير'
when 'March' then 'مارس'
when 'April'then 'ابريل'
when 'May' then 'مايو'
when 'June'then 'يونيو'
when 'July'then 'يوليو'
when 'August' then 'اغسطس'
when 'September'then 'سبتمبر'
when 'October' then 'اكتوبر'
when 'November'then 'نوفمبر'
when 'December'then 'ديسمبر'
end as CurrentMonth </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
