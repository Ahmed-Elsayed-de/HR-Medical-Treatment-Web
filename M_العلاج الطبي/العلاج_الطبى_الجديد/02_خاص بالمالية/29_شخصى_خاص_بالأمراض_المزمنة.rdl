<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:cl="http://schemas.microsoft.com/sqlserver/reporting/2010/01/componentdefinition" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2010/01/reportdefinition">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=Misserver;Initial Catalog=MT</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>fd1359a3-30a3-46e3-afa1-75d736617758</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@Endemic">
            <Value>=Parameters!Endemic.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Regist">
            <Value>=Parameters!Regist.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@YearMT">
            <Value>=Parameters!YearMT.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
HRdata.Code,    
HRdata.Regist_No1, 
HRdata.E_Name, 
HRdata.Endemic, 
SUM(MtTickets.CoSharehold1+MtTickets.CoSharehold2) as [حصة الشركة],
SUM(MtTickets.EmpSharehold1+MtTickets.EmpSharehold2) as [حصة العامل]

FROM         
HRdata AS HRdata LEFT OUTER JOIN
MtTickets ON HRdata.Code = MtTickets.code 
WHERE     
(HRdata.Endemic in(@Endemic)) AND 
(HRdata.Regist_No1 IN (@Regist)) AND 
(MtTickets.YearMT IN (@YearMT)) AND 
(MtTickets.TreatKind IN ('علاج شخصي')) and (HRdata.Endemic is not null ) and (HRdata.Endemic &lt;&gt; 'بدون')
GROUP BY 
HRdata.Code,
HRdata.Regist_No1, 
HRdata.E_Name, 
HRdata.Endemic
ORDER BY HRdata.Regist_No1</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Regist_No1">
          <DataField>Regist_No1</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="E_Name">
          <DataField>E_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Endemic">
          <DataField>Endemic</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="حصة_الشركة">
          <DataField>حصة الشركة</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="حصة_العامل">
          <DataField>حصة العامل</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Regist">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select HRdata.Regist_No1 from HRdata</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Regist_No1">
          <DataField>Regist_No1</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Endemic">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct HRdata.Endemic from HRdata where ( HRdata.Endemic not like 'بدون') and (HRdata.Endemic is not null) </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Endemic">
          <DataField>Endemic</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DataSet2">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>select distinct MtTickets.TreatKind from MtTickets where MtTickets.TreatKind is not null </CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="TreatKind">
          <DataField>TreatKind</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
