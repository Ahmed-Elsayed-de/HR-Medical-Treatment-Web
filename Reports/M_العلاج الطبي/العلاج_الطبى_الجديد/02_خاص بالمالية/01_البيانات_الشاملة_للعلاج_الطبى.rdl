      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT     
HRdata.Code, 
HRdata.Regist_No1, 
HRdata.E_Name, 
MtTickets.YearMT, 
HRdata.نوع_التعاقد, 
MtTickets.Id_3101, 
MtTickets.TarnsDate, 
MtTickets.TreatDate, 
MtTickets.Contractors, 
MtTickets.TreatType, 
MtTickets.TreatTypeId, 
MtTickets.TreatKind, 
MtTickets.relatives, 
MtTickets.DokConfirm, 
MtTickets.DokConfirmDate, 
MtTickets.Contractors2, 
MtTickets.pharmConfirm, 
MtTickets.pharmConfirmDate, 
MtTickets.notes, 
MtTickets.code AS Expr1, 
MtTickets.Localdeduct, 
MtTickets.ForeignDeduct, 
MtTickets.LocaldeductAfter, 
MtTickets.ForeignDeductAfter, 
MtTickets.CoSharehold, 
MtTickets.CoShareholdSurg, 
MtTickets.EmpSharehold, 
MtTickets.Localdeduct1, 
MtTickets.ForeignDeduct1, 
MtTickets.LocaldeductAfter1, 
MtTickets.ForeignDeductAfter1, 
MtTickets.CoSharehold1, 
MtTickets.CoShareholdSurg1, 
MtTickets.EmpSharehold1, 
MtTickets.Check1, 
MtTickets.Localdeduct2, 
MtTickets.ForeignDeduct2, 
MtTickets.LocaldeductAfter2, 
MtTickets.ForeignDeductAfter2, 
MtTickets.CoSharehold2, 
MtTickets.CoShareholdSurg2, 
MtTickets.EmpSharehold2, 
MtTickets.Check2, 
MtTickets.LocaldeductF, 
MtTickets.ForeignDeductF, 
MtTickets.LocaldeductAfterF, 
MtTickets.ForeignDeductAfterF, 
MtTickets.CoShareholdF, 
MtTickets.CoShareholdSurgF, 
MtTickets.EmpShareholdF, 
MtTickets.CheckF, 
MtTickets.LocaldeductS, 
MtTickets.ForeignDeductS, 
MtTickets.LocaldeductAfterS, 
MtTickets.ForeignDeductAfterS, 
MtTickets.CoShareholdS, 
MtTickets.EmpShareholdS, 
MtTickets.CheckS, 
MtTickets.CoShareholdNet, 
MtTickets.EmpShareholdNet, 
MtTickets.CoShareholdSurgNet, 
MtTickets.CaseName, 
MtTickets.BillingNo, 
MtTickets.BillingNo1, 
MtTickets.PharmMemo, 
MtTickets.YearMT AS Expr2, 
MtTickets.HospitalLevel,
case MtTickets.FamilyBox when 'True' then 'نعم' when 'False' then 'لا'End as FamilyBox, 
MtTickets.LocalDeduct3, 
MtTickets.ForignDeduct, 
MtTickets.HospitalDeduct, 
MtTickets.categorization, 
MtTickets.[Check],
HRdata.الموقف_الحالي
FROM         
HRdata INNER JOIN MtTickets ON HRdata.Code = MtTickets.code
WHERE (MtTickets.YearMT in (@Year))and 
      (HRdata.Regist_No1 in (@RegistNo))and
      (HRdata.نوع_التعاقد in (@Contract))and
      (MtTickets.Contractors2 in (@Contractors2))and 
      (MtTickets.Contractors in (@Contractors))and 
      (MtTickets.TreatType in (@TreatType))and 
      (MtTickets.TreatKind in (@TreatKind))and 
      (MtTickets.relatives in (@relatives))and 
      (MtTickets.DokConfirm in (@DokConfirm))and 
      (MtTickets.pharmConfirm in (@pharmConfirm)) and
      (HRdata.الموقف_الحالي  in (@CurStatus))   
ORDER BY HRdata.Regist_No1, MtTickets.Id_3101</CommandText>
        <QueryParameters>
          <QueryParameter Name="@Year">
            <Value>=Parameters!Year.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@RegistNo">
            <Value>=Parameters!RegistNo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Contract">
            <Value>=Parameters!Contract.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Contractors">
            <Value>=Parameters!Contractors.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Contractors2">
            <Value>=Parameters!Contractors2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TreatType">
            <Value>=Parameters!TreatType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TreatKind">
            <Value>=Parameters!TreatKind.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@relatives">
            <Value>=Parameters!relatives.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DokConfirm">
            <Value>=Parameters!DokConfirm.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@pharmConfirm">
            <Value>=Parameters!pharmConfirm.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CurStatus">
            <Value>=Parameters!CurStatus.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
